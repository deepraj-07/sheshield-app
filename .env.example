# =============================================================================
# SheShield — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# =============================================================================

# ---- Firebase (Android) -----------------------------------------------------
# Obtain from: Firebase Console → Project Settings → Your apps → Android
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_APP_ID=your_firebase_app_id_here
FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app

# ---- Google Maps ------------------------------------------------------------
# Obtain from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ---- FCM Server Key (Legacy) ------------------------------------------------
# Obtain from: Firebase Console → Project Settings → Cloud Messaging → Server key
# Leave empty to fall back to Firestore notification queue (Cloud Functions).
FCM_SERVER_KEY=

# ---- Stealth Mode -----------------------------------------------------------
# Secret tap code to activate stealth mode. Change from the default '0000'.
STEALTH_MODE_CODE=0000

# ---- OSM Overpass API -------------------------------------------------------
# Public endpoint — override only if using a self-hosted instance.
OSM_OVERPASS_API_URL=https://overpass-api.de/api/interpreter
